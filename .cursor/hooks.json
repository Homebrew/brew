{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "npx block-no-verify@1.1.2",
        "event": "beforeShellExecution"
      }
    ],
    "afterFileEdit": [
      {
        "command": "./bin/brew style --changed --fix"
      },
      {
        "command": "./bin/brew typecheck"
      }
    ],
    "stop": [
      {
        "command": "./bin/brew tests --changed"
      }
    ]
  }
}